# Groq Configuration for Natural Language Ordering
# Get your API key from: https://console.groq.com/keys

# Required for strict sender filtering:
# Only this number can trigger bot responses (digits only, with country code).
# Example: 919876543210
ALLOWED_PHONE_NUMBER=
ALLOWED_CHAT_JID=
ALLOW_FROM_ME=false

GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: Groq model (defaults to llama-3.3-70b-versatile)
# Other examples: llama-3.1-8b-instant, deepseek-r1-distill-llama-70b
GROQ_MODEL=llama-3.3-70b-versatile

# Required to sync orders with KiranaKeeper website
FIREBASE_EMAIL=your-firebase-login-email@example.com
FIREBASE_PASSWORD=your-firebase-login-password

# Optional fallback when email/password auth is unavailable.
# Set this to the Firestore uid under users/{uid} to skip uid discovery.
FIREBASE_USER_ID=your_firestore_user_uid
